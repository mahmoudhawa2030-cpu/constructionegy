# Copy to `.env.local` and fill with values from Supabase → Settings → API.
# Never commit `.env.local`. `SUPABASE_SERVICE_ROLE_KEY` must stay server-only (Vercel env, not NEXT_PUBLIC_*).
#
# Vercel / production: if signup shows an email rate-limit error, configure custom SMTP in the Supabase
# Dashboard (not in this file). See https://supabase.com/docs/guides/auth/auth-smtp

# Capacitor (Android/iOS): set before `npx cap sync` so WebView loads your deployed Next app (overrides default in capacitor.config.ts).
# NEXT_PUBLIC_APP_URL=https://constructionegy.vercel.app
#
# Signup uses emailRedirectTo = {current origin}/profile — add each origin in Supabase → Authentication →
# URL Configuration → Redirect URLs (e.g. http://localhost:3000/** and your production URL).
#
# Password reset: the app uses the browser’s current origin when the user submits “Forgot password”, so production
# sends production links. For server-only use, set NEXT_PUBLIC_APP_URL or rely on VERCEL_URL on Vercel.
#
# Supabase → Authentication → URL Configuration:
# - Site URL: your primary production origin (e.g. https://constructionegy.vercel.app).
# - Redirect URLs: include (wildcards OK):
#     https://your-production-domain.com/auth/callback**
#     https://your-production-domain.com/auth/confirm**
#     https://your-production-domain.com/**
#     https://*.vercel.app/**
#     http://localhost:3000/**
#
# Password reset: user lands on /auth/callback — PKCE code exchange runs in the browser (same cookie store as
# “Forgot password”). If the link is opened on another device/browser, use /auth/confirm + token_hash template
# — see app/auth/confirm/route.ts

# Digits in signup confirmation email; must match Supabase Auth email OTP length (Dashboard / config).
# NEXT_PUBLIC_AUTH_EMAIL_OTP_LENGTH=8

NEXT_PUBLIC_SUPABASE_URL=
# Use one of these (project publishable / anon key):
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Server-only: auth.admin.deleteUser and similar. Do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# FCM (optional): Firebase Console → Project settings → Service accounts → Generate new private key.
# Paste the full JSON on one line or use Vercel multiline secret. Omit to disable server push sends.
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Same secret in Authorization: Bearer … for POST /api/push/notify (Supabase Database Webhook on public.messages INSERT).
# PUSH_NOTIFY_SECRET=

# Used by `npm run push:webhook` to print your production notify URL (optional locally).
# NEXT_PUBLIC_APP_URL=https://constructionegy.vercel.app

# ── Migration-ready vars (not required today, set when self-hosting) ──────────

# Storage base URL — override when moving from Supabase Storage to self-hosted MinIO / S3.
# On Supabase: leave unset (auto-derived from NEXT_PUBLIC_SUPABASE_URL).
# On Hetzner: NEXT_PUBLIC_STORAGE_BASE_URL=https://storage.yourdomain.com
# NEXT_PUBLIC_STORAGE_BASE_URL=

# Redis connection string — used for feed caching when traffic grows.
# On Upstash (serverless, free tier): REDIS_URL=rediss://...upstash.io:6380
# On Hetzner (self-hosted): REDIS_URL=redis://localhost:6379
# REDIS_URL=
